    var horario: String
    var cor: Color
    var icone: String
}

class HackaGuardViewModel: ObservableObject {
    @Published var sistemaArmado: Bool = true
    
    @Published var data = HackaGuardData(
        status: "Casa segura",
        mensagem: "Todos os sensores estão funcionando normalmente",
        usuario: "Andrew",
        rfidAutorizado: true,
        distancia: 82,
        gas: 230,
        som: 120,
        ultimoEvento: "Andrew entrou às 14:32"
    )
    
    @Published var historico: [EventoHistorico] = [
        EventoHistorico(
            tipo: "Acesso",
            titulo: "Entrada autorizada",
            descricao: "Andrew entrou usando RFID",
            horario: "14:32",
            cor: AppColors.verdeSeguro,
            icone: "person.badge.key.fill"
        ),
        EventoHistorico(
            tipo: "Sistema",
            titulo: "Casa segura",
            descricao: "Todos os sensores estão normais",
            horario: "14:20",
            cor: AppColors.azulMarca,
            icone: "checkmark.shield.fill"
        ),
        EventoHistorico(
            tipo: "Sensor",
            titulo: "Sensor de gás normal",
            descricao: "Nenhum vapor elevado detectado",
            horario: "14:10",
            cor: AppColors.verdeSeguro,
            icone: "wind"
        ),
        EventoHistorico(
            tipo: "Sensor",
            titulo: "Barulho baixo",
            descricao: "Ambiente silencioso",
            horario: "13:55",
            cor: AppColors.verdeSeguro,
            icone: "waveform"
        ),
        EventoHistorico(
            tipo: "Sistema",
            titulo: "Sistema iniciado",
            descricao: "HackaGuard foi iniciado",
            horario: "13:40",
            cor: AppColors.azulMarca,
            icone: "power"
        )
    ]
    
    func corStatus() -> Color {
        let texto = data.status.lowercased()
        
        if texto.contains("alerta") || texto.contains("perigo") {
            return AppColors.vermelhoAlerta
        } else if texto.contains("atenção") {
            return AppColors.amareloAtencao
        } else {
            return AppColors.verdeSeguro
        }
    }
    
    func iconeStatus() -> String {
        let texto = data.status.lowercased()
        
        if texto.contains("alerta") || texto.contains("perigo") {
            return "exclamationmark.triangle.fill"
        } else if texto.contains("atenção") {
            return "exclamationmark.circle.fill"
        } else {
            return "checkmark.shield.fill"
        }
    }
    
    func horaAtual() -> String {
        let formatter = DateFormatter()
        formatter.dateFormat = "HH:mm"
        return formatter.string(from: Date())
    }
    
    func adicionarEvento(tipo: String, titulo: String, descricao: String, cor: Color, icone: String) {
        let evento = EventoHistorico(
            tipo: tipo,
            titulo: titulo,
            descricao: descricao,
            horario: horaAtual(),
            cor: cor,
            icone: icone
        )
        
        historico.insert(evento, at: 0)
    }
}

